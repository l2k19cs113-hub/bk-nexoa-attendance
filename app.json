{
  "expo": {
    "name": "BK Nexora Tech Attendance",
    "slug": "bk-nexora-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bknexora.attendance",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location for attendance check-in.",
        "NSLocationAlwaysUsageDescription": "We need your location for attendance check-in.",
        "NSCameraUsageDescription": "We need camera access for report attachments.",
        "NSPhotoLibraryUsageDescription": "We need photo access to upload report proofs."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.bknexora.attendance",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#6C63FF"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow BK Nexora to access your location for accurate attendance check-ins."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload report attachments.",
          "cameraPermission": "The app accesses your camera to let you take photos for reports."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0F1E",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "scheme": "bknexora",
    "extra": {
      "eas": {
        "projectId": "cf1d0271-3e24-4abb-af13-6deb929435c0"
      }
    }
  }
}
